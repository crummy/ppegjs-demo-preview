---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const collection = await getCollection("examples");
const examples = collection.map((c) => c.data);
const initialExample = examples.find((e) => e.highlighted)?.title;
---

<script>
  import { compile } from "ppegjs/pPEG.js";
  import type { Code, CodeError, Parse, ParseError } from "ppegjs/pPEG.js";

  import {
    generateTreeOutput,
    findError,
    generateTraceOutput,
    generateGrammarCompileErrorOutput,
    type Range,
    highlight,
  } from "../lib/generate-output";
  import { getSelectionOffsets, restoreSelectionOffsets } from "../lib/caret";
  import type { TraceOptions } from "../lib/generate-output.ts";

  // A little helper to save us from doing null checks later
  const getElement = <T extends Element>(selector: string): T => {
    const element = document.querySelector<T>(selector);
    if (!element) throw new Error("No element found: " + selector);
    return element;
  };

  const examplesSelect = getElement<HTMLSelectElement>("#examples");
  const scratchButton = getElement<HTMLButtonElement>("#scratch");
  const grammar = getElement<HTMLDivElement>("#grammar");
  const input = getElement<HTMLDivElement>("#input");
  const output = getElement<HTMLDivElement>("#output");
  const outputModeRadios = document.querySelectorAll<HTMLInputElement>(
    'input[name="output-mode"]',
  );
  const outputModeFromDom = (): OutputMode => {
    const selected = Array.from(outputModeRadios).find((r) => r.checked)?.value;
    if (selected === "trace" || selected === "json") {
      return selected;
    }
    return "tree";
  };

  type OutputMode = "tree" | "trace" | "json";
  type GrammarError = CodeError | ParseError;

  type DemoState = {
    selectedExample: string;
    workspace: "example" | "scratch";
    grammarText: string;
    inputText: string;
    outputMode: OutputMode;
    error: boolean;
    options: TraceOptions;
  };

  const STORAGE_KEYS = {
    scratchGrammar: "scratch-grammar",
    scratchInput: "scratch-input",
    workspace: "workspace",
    showAnonymous: "show-anonymous",
    showEmpty: "show-empty",
    selectedExample: "selected-example",
    outputMode: "output-mode",
  } as const;

  const readStorage = (key: string): string | null => {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  };

  const writeStorage = (key: string, value: string) => {
    try {
      localStorage.setItem(key, value);
    } catch {
      // ignore storage errors (private mode / blocked storage)
    }
  };

  const State: DemoState = {
    selectedExample: examplesSelect.value,
    workspace: "example",
    grammarText: "",
    inputText: "",
    outputMode: outputModeFromDom(),
    error: false,
    options: { showAnonymous: false, showEmpty: false },
  };

  const updateState = (partial: Partial<DemoState>) => {
    Object.assign(State, partial);
  };

  const saveScratch = () => {
    if (State.workspace !== "scratch") return;
    writeStorage(STORAGE_KEYS.scratchGrammar, State.grammarText);
    writeStorage(STORAGE_KEYS.scratchInput, State.inputText);
  };

  const toggleScratch = () => {
    if (State.workspace === "example") {
      updateState({
        workspace: "scratch",
        grammarText:
          readStorage(STORAGE_KEYS.scratchGrammar) ??
          "# Enter your grammar here.\na = 'a'",
        inputText: readStorage(STORAGE_KEYS.scratchInput) ?? "a",
      });
      runWithCaret();
    } else {
      updateState({ workspace: "example" });
      loadSelectedExample(State.selectedExample);
    }
  };

  // saves the current cursor location, compiles, then restores the location
  // necessary to ensure cursor location isn't reset after highlighting
  const runWithCaret = () => {
    const active = document.activeElement;
    const target =
      active === input || active === grammar ? (active as HTMLElement) : null;
    const selection = target ? getSelectionOffsets(target) : null;

    let compileOutput: Code | null = null;
    let parseOutput: Parse | null = null;
    let compileError: GrammarError | null = null;
    try {
      compileOutput = compile(State.grammarText);
      parseOutput = compileOutput.parse(State.inputText);
      updateState({ error: false });
    } catch (error) {
      updateState({ error: true });
      compileError = isGrammarError(error) ? error : null;
      if (!compileError) throw error;
    }

    render(compileOutput, parseOutput, compileError);

    if (target && selection) {
      target.focus();
      restoreSelectionOffsets(target, selection.start, selection.end);
    }
  };

  const render = (
    compileOutput: Code | null,
    parseOutput: Parse | null,
    compileError: GrammarError | null = null,
  ) => {
    if (examplesSelect.value !== State.selectedExample) {
      examplesSelect.value = State.selectedExample;
    }
    scratchButton.innerText =
      State.workspace === "example" ? "Scratch" : "Exit Scratch";
    if (editableText(grammar) !== State.grammarText) {
      grammar.textContent = State.grammarText;
    }
    if (editableText(input) !== State.inputText) {
      input.textContent = State.inputText;
    }
    State.outputMode === "trace"
      ? document.querySelector(".trace-options")?.classList.remove("hidden")
      : document.querySelector(".trace-options")?.classList.add("hidden");

    document
      .querySelectorAll(".error-alert")
      .forEach((e) =>
        State.error ? e.classList.remove("hidden") : e.classList.add("hidden"),
      );

    for (const radio of outputModeRadios) {
      radio.checked = radio.value === State.outputMode;
    }

    let outputText = "";
    let grammarHighlights: Range[] = [];
    let errorHighlights: Range[] = [];
    let inputHighlights: Range[] = [];
    let spanHighlights: Range[] = [];
    let captureHighlights: Range[] = [];

    if (compileError || (compileOutput && !compileOutput?.ok)) {
      const errorOutput = generateGrammarCompileErrorOutput(
        State.grammarText,
        compileError ?? compileOutput,
      );
      outputText = errorOutput.text;
      grammarHighlights = errorOutput.highlights;
    } else if (parseOutput) {
      if (State.outputMode === "json") {
        outputText = JSON.stringify(parseOutput.ptree(), null, 2);
      } else if (State.outputMode === "trace") {
        const traceOutput = generateTraceOutput(parseOutput);
        outputText = traceOutput.text;
        errorHighlights = traceOutput.errors;
        spanHighlights = traceOutput.spans;
        captureHighlights = traceOutput.captures;
        grammarHighlights = failedRuleHighlights(State.grammarText, {
          fault_rule: failedRuleName(parseOutput),
        });
      } else {
        const treeOutput = generateTreeOutput(parseOutput);
        outputText = treeOutput.text;
        errorHighlights = treeOutput.errors;
        grammarHighlights = failedRuleHighlights(State.grammarText, {
          fault_rule: failedRuleName(parseOutput),
        });
      }

      if (!parseOutput.ok) {
        const error = findError(
          parseOutput.trace,
          State.inputText.length,
          State.inputText,
        );
        inputHighlights = error ? [error] : [];
      }
    }

    output.textContent = outputText;
    CSS.highlights?.clear();
    highlight(grammar, grammarHighlights, "highlight-errors-grammar");
    highlight(output, errorHighlights, "highlight-errors-output");
    highlight(input, inputHighlights, "highlight-errors-input");
    highlight(output, spanHighlights, "highlight-spans");
    highlight(output, captureHighlights, "highlight-captures");
  };

  function isGrammarError(error: unknown): error is GrammarError {
    if (!error || typeof error !== "object" || !("kind" in error)) {
      return false;
    }
    return error.kind === "grammar" || error.kind === "parse";
  }

  function failedRuleHighlights(
    grammar: string,
    { fault_rule }: { fault_rule?: string } = {},
  ) {
    if (fault_rule) {
      const re = new RegExp(`^\\s*${fault_rule}`, "m");
      const start = grammar.search(re);
      const end = start + fault_rule.length - 1;
      return [{ start, end }];
    }
    return [];
  }

  function failedRuleName(parseOutput: Parse): string | undefined {
    if (parseOutput.ok || parseOutput.fell_short) return undefined;
    const node = parseOutput.trace[parseOutput.max_trace];
    return node ? parseOutput.code.id_name(node.idx()) : undefined;
  }

  const loadSelectedExample = (selected: string) => {
    const option = getElement<HTMLOptionElement>(`#option-${selected}`);
    updateState({
      selectedExample: selected,
      workspace: "example",
      grammarText: option.dataset.grammar ?? "",
      inputText: option.dataset.input ?? "",
    });
    runWithCaret();
  };

  const editableText = (editable: HTMLElement) => {
    return (editable.textContent ?? "").replace(/\r\n?/g, "\n");
  };

  const setEditableText = (
    editable: HTMLElement,
    text: string,
    selectionOffset: number,
    keepTrailingCaretLine = false,
  ) => {
    editable.textContent = text;

    if (keepTrailingCaretLine && text.endsWith("\n")) {
      const trailingCaretLine = document.createElement("br");
      trailingCaretLine.dataset.contenteditableSentinel = "true";
      editable.appendChild(trailingCaretLine);

      const range = document.createRange();
      range.setStartAfter(trailingCaretLine);
      range.setEndAfter(trailingCaretLine);

      const selection = window.getSelection();
      selection?.removeAllRanges();
      selection?.addRange(range);
      return;
    }

    restoreSelectionOffsets(
      editable,
      Math.min(selectionOffset, text.length),
      Math.min(selectionOffset, text.length),
    );
  };

  const isLineBreakInput = (event: InputEvent) =>
    event.inputType === "insertParagraph" ||
    event.inputType === "insertLineBreak" ||
    event.data === "\n" ||
    event.data === "\r";

  const replaceRange = (
    text: string,
    start: number,
    end: number,
    replacement: string,
  ) => text.slice(0, start) + replacement + text.slice(end);

  const bindEditable = (
    editable: HTMLElement,
    readText: () => string,
    updateText: (text: string) => void,
  ) => {
    const commit = (text: string) => {
      updateText(text);
      saveScratch();
      runWithCaret();
    };

    editable.addEventListener("beforeinput", (event) => {
      const inputEvent = event as InputEvent;
      if (!isLineBreakInput(inputEvent)) return;

      const selection = getSelectionOffsets(editable);
      if (!selection) return;

      // Browsers serialize contenteditable line breaks inconsistently. Update
      // the plaintext model directly, then add a <br> as the visible caret line.
      event.preventDefault();
      const text = replaceRange(
        readText(),
        selection.start,
        selection.end,
        "\n",
      );
      setEditableText(editable, text, selection.start + 1, true);
      commit(text);
    });

    editable.addEventListener("input", () => {
      const selection = getSelectionOffsets(editable);
      const rawText = editable.textContent ?? "";
      const text = editableText(editable);
      const hasStaleCaretLine =
        editable.lastElementChild instanceof HTMLBRElement &&
        editable.lastElementChild.dataset.contenteditableSentinel === "true" &&
        !text.endsWith("\n");

      if (rawText !== text || hasStaleCaretLine) {
        setEditableText(
          editable,
          text,
          selection?.start ?? text.length,
          text.endsWith("\n"),
        );
      }

      commit(text);
    });
  };

  examplesSelect.addEventListener("change", () => {
    loadSelectedExample(examplesSelect.value);
  });
  scratchButton.addEventListener("click", toggleScratch);

  for (const radio of outputModeRadios) {
    radio.addEventListener("change", () => {
      const outputMode = outputModeFromDom();
      updateState({ outputMode });
      writeStorage(STORAGE_KEYS.outputMode, outputMode);
      runWithCaret();
    });
  }

  bindEditable(
    input,
    () => State.inputText,
    (inputText) => updateState({ inputText }),
  );
  bindEditable(
    grammar,
    () => State.grammarText,
    (grammarText) => updateState({ grammarText }),
  );

  const defaultSelectedExample = examplesSelect
    .querySelectorAll("option")
    .values()
    .find((e) => e.dataset["defaultSelected"] === "true")?.value;
  const outputModeFromStorage = readStorage(STORAGE_KEYS.outputMode);
  updateState({
    selectedExample:
      readStorage(STORAGE_KEYS.selectedExample) ?? defaultSelectedExample,
    outputMode:
      outputModeFromStorage === "trace" || outputModeFromStorage === "json"
        ? outputModeFromStorage
        : "tree",
  });

  const workspaceFromStorage = readStorage(STORAGE_KEYS.workspace);
  if (workspaceFromStorage === "scratch") {
    toggleScratch();
  } else {
    loadSelectedExample(State.selectedExample);
  }

  window.addEventListener("beforeunload", () => {
    saveScratch();
    writeStorage(STORAGE_KEYS.workspace, State.workspace);
    writeStorage(STORAGE_KEYS.showEmpty, State.options.showEmpty.toString());
    writeStorage(STORAGE_KEYS.selectedExample, State.selectedExample);
    writeStorage(STORAGE_KEYS.outputMode, State.outputMode);
  });
</script>

<Layout>
  <style is:global>
    body {
      display: grid;
      grid-template-areas:
        "grammar output"
        "input   output";
      grid-template-rows: 1fr 1fr;
      grid-template-columns: 1fr 1fr;
      width: 100%;
      height: 100vh;
      padding: 1em;
      gap: 0.5em;
      box-sizing: border-box;
    }

    #input,
    #grammar,
    #output {
      margin: 2px;
      padding: 5px;
      white-space: pre-wrap;
      font-family:
        "Courier Line Draw", "Courier Prime", "Courier New", monospace;
      resize: none;
    }

    #output {
      white-space: pre;
    }

    .content-container {
      overflow-y: scroll;
    }

    .node-label {
      border-radius: 3px;
      padding: 0 2px;
    }

    .input {
      grid-area: input;
    }

    .output {
      grid-area: output;
    }

    .footer {
      grid-area: footer;
    }

    .grammar,
    .input,
    .output {
      display: grid;
      grid-template-rows: auto 1fr;
      border: thin solid gray;
      min-height: 0; /** necessary to prevent divs from growing below screen **/
    }

    .header {
      padding: 5px;
      border-bottom: thin solid gray;
      background: whitesmoke;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
    }

    .trace-options {
      display: flex;
      justify-content: end;
      gap: 0.5rem;
      padding-top: 0.5rem;
      flex-grow: 1;
    }

    .output-mode {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .output-mode-option {
      display: inline-flex;
      align-items: center;
      gap: 0.2rem;
    }

    .examples {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }

    #scratch {
      padding: 0.1rem 0.5rem;
      border: thin solid gray;
      background: white;
      cursor: pointer;
    }

    #scratch.active {
      background: #ddd;
    }

    ::highlight(highlight-spans) {
      color: #555;
    }

    ::highlight(highlight-captures) {
      color: #999;
    }

    ::highlight(highlight-errors-output),
    ::highlight(highlight-errors-grammar),
    ::highlight(highlight-errors-input) {
      text-decoration: red wavy underline;
      background-color: #ffb3ba !important;
    }

    .error-alert {
      flex-grow: 1;
      padding-left: 0.3em;
    }

    .hidden {
      display: none;
    }

    @media (max-width: 768px) {
      body {
        grid-template-areas:
          "title"
          "grammar"
          "input"
          "output"
          "footer";
        grid-template-columns: 1fr;
        grid-template-rows: auto;
        height: auto;
      }

      /**inputs should no longer be scrollable**/
      #grammar,
      #input,
      #output {
        overflow-y: visible;
      }

      /**instead, they should grow**/
      .grammar,
      .input,
      .output {
        min-height: auto;
      }
    }
  </style>

  <div class="grammar">
    <div class="header">
      <label for="grammar">Grammar</label>
      <span class="examples">
        <label for="examples">Examples: </label>
        <select name="examples" id="examples">
          {
            examples.map(({ title, grammar, input }) => (
              <option
                id={`option-${title}`}
                value={title}
                data-grammar={grammar}
                data-input={input}
                data-default-selected={title == initialExample}
              >
                {title}
              </option>
            ))
          }
        </select>
        <button id="scratch" type="button">Scratch</button>
      </span>
    </div>
    <div
      class="content-container"
      id="grammar"
      contenteditable="plaintext-only"
      spellcheck="false"
    >
    </div>
  </div>
  <div class="input">
    <div class="header">
      <label for="input">Input</label>
    </div>
    <div
      class="content-container"
      id="input"
      contenteditable="plaintext-only"
      spellcheck="false"
    >
    </div>
  </div>
  <div class="output">
    <div class="header">
      Parse Tree
      <span class="error-alert" title="An error occurred during processing"
        >⚠️</span
      >
      <span class="output-mode">
        <label class="output-mode-option">
          <input type="radio" name="output-mode" value="tree" checked />
          Tree
        </label>
        <label class="output-mode-option">
          <input type="radio" name="output-mode" value="trace" />
          Trace
        </label>
        <label class="output-mode-option">
          <input type="radio" name="output-mode" value="json" />
          JSON
        </label>
      </span>
    </div>
    <div class="content-container">
      <div id="output"></div>
    </div>
  </div>
</Layout>
