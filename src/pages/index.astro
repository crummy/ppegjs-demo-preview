---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const collection = await getCollection("examples");
const examples = collection.map((c) => c.data);
const initialExample = examples.find((e) => e.highlighted)?.title;
---

<script>
  import { ppeg } from "ppegjs";

  import {
    generateTreeOutput,
    findError,
    generateTraceOutput,
    generateGrammarCompileErrorOutput,
    type Range,
    highlight,
  } from "../lib/generate-output";
  import { getSelectionOffsets, restoreSelectionOffsets } from "../lib/caret";
  import type { TraceOptions } from "../lib/generate-output.ts";

  // A little helper to save us from doing null checks later
  const getElement = <T extends Element>(selector: string): T => {
    const element = document.querySelector<T>(selector);
    if (!element) throw new Error("No element found: " + selector);
    return element;
  };

  const examplesSelect = getElement<HTMLSelectElement>("#examples");
  const scratchButton = getElement<HTMLButtonElement>("#scratch");
  const grammar = getElement<HTMLDivElement>("#grammar");
  const input = getElement<HTMLDivElement>("#input");
  const output = getElement<HTMLDivElement>("#output");
  const outputModeRadios = document.querySelectorAll<HTMLInputElement>(
    'input[name="output-mode"]',
  );
  const outputModeFromDom = (): OutputMode => {
    const selected = Array.from(outputModeRadios).find((r) => r.checked)?.value;
    if (selected === "trace" || selected === "json") {
      return selected;
    }
    return "tree";
  };

  type CompileOutput = ReturnType<typeof ppeg.compile>;
  type CompiledOk = Extract<CompileOutput, { ok: true }>;
  type ParseOutput = ReturnType<CompiledOk["parse"]>;
  type OutputMode = "tree" | "trace" | "json";

  type DemoState = {
    selectedExample: string;
    workspace: "example" | "scratch";
    grammarText: string;
    inputText: string;
    outputMode: OutputMode;
    error: boolean;
    options: TraceOptions;
  };

  const STORAGE_KEYS = {
    scratchGrammar: "scratch-grammar",
    scratchInput: "scratch-input",
    workspace: "workspace",
    showAnonymous: "show-anonymous",
    showEmpty: "show-empty",
    selectedExample: "selected-example",
    outputMode: "output-mode",
  } as const;

  const readStorage = (key: string): string | null => {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  };

  const writeStorage = (key: string, value: string) => {
    try {
      localStorage.setItem(key, value);
    } catch {
      // ignore storage errors (private mode / blocked storage)
    }
  };

  const State: DemoState = {
    selectedExample: examplesSelect.value,
    workspace: "example",
    grammarText: "",
    inputText: "",
    outputMode: outputModeFromDom(),
    error: false,
    options: { showAnonymous: false, showEmpty: false },
  };

  const updateState = (partial: Partial<DemoState>) => {
    Object.assign(State, partial);
  };

  const saveScratch = () => {
    if (State.workspace !== "scratch") return;
    writeStorage(STORAGE_KEYS.scratchGrammar, State.grammarText);
    writeStorage(STORAGE_KEYS.scratchInput, State.inputText);
  };

  const toggleScratch = () => {
    if (State.workspace === "example") {
      updateState({
        workspace: "scratch",
        grammarText: readStorage(STORAGE_KEYS.scratchGrammar) ?? "",
        inputText: readStorage(STORAGE_KEYS.scratchInput) ?? "",
      });
      runWithCaret();
    } else {
      updateState({ workspace: "example" });
      loadSelectedExample(State.selectedExample);
    }
  };

  // saves the current cursor location, compiles, then restores the location
  // necessary to ensure cursor location isn't reset after highlighting
  const runWithCaret = () => {
    const active = document.activeElement;
    const target =
      active === input || active === grammar ? (active as HTMLElement) : null;
    const selection = target ? getSelectionOffsets(target) : null;

    const { compileOutput, parseOutput } = compile();
    updateState({
      error: compileOutput.ok === false || parseOutput?.ok === false,
    });
    render(compileOutput, parseOutput);

    if (target && selection) {
      target.focus();
      restoreSelectionOffsets(target, selection.start, selection.end);
    }
  };

  const compile = (): {
    compileOutput: CompileOutput;
    parseOutput: ParseOutput | null;
  } => {
    const compileOutput = ppeg.compile(State.grammarText);
    if (!compileOutput.ok) {
      return { compileOutput, parseOutput: null };
    }
    const parseOutput = compileOutput.parse(State.inputText);
    return { compileOutput, parseOutput };
  };

  const render = (compileOutput: CompileOutput, parseOutput: ParseOutput) => {
    if (examplesSelect.value !== State.selectedExample) {
      examplesSelect.value = State.selectedExample;
    }
    scratchButton.innerText =
      State.workspace === "example" ? "Scratch" : "Exit Scratch";
    if (grammar.textContent !== State.grammarText) {
      grammar.textContent = State.grammarText;
    }
    if (input.textContent !== State.inputText) {
      input.textContent = State.inputText;
    }
    State.outputMode === "trace"
      ? document.querySelector(".trace-options")?.classList.remove("hidden")
      : document.querySelector(".trace-options")?.classList.add("hidden");

    document
      .querySelectorAll(".error-alert")
      .forEach((e) =>
        State.error ? e.classList.remove("hidden") : e.classList.add("hidden"),
      );

    for (const radio of outputModeRadios) {
      radio.checked = radio.value === State.outputMode;
    }

    let outputText = "";
    let grammarHighlights: Range[] = [];
    let errorHighlights: Range[] = [];
    let inputHighlights: Range[] = [];
    let spanHighlights: Range[] = [];
    let captureHighlights: Range[] = [];

    if (compileOutput && !compileOutput?.ok) {
      const errorOutput = generateGrammarCompileErrorOutput(
        State.grammarText,
        compileOutput,
      );
      outputText = errorOutput.text;
      grammarHighlights = errorOutput.highlights;
    } else if (parseOutput) {
      if (State.outputMode === "json") {
        outputText = JSON.stringify(parseOutput.ptree, null, 2);
      } else if (State.outputMode === "trace") {
        const trace = ppeg.show_trace(parseOutput)
        const traceOutput = generateTraceOutput(
          State.inputText,
          trace,
          parseOutput.error,
          State.options,
        );
        outputText = traceOutput.text;
        errorHighlights = traceOutput.errors;
        console.log(errorHighlights);
        spanHighlights = traceOutput.spans;
        captureHighlights = traceOutput.captures;
      } else {
        outputText = generateTreeOutput(parseOutput.ptree, parseOutput.error);
      }

      if (!parseOutput.ok) {
        const error = findError(
          parseOutput.trace_history,
          State.inputText.length,
          State.inputText,
        );
        inputHighlights = error ? [error] : [];
      }
    }

    output.textContent = outputText;
    CSS.highlights?.clear();
    highlight(grammar, grammarHighlights, "highlight-errors-grammar");
    highlight(output, errorHighlights, "highlight-errors-output");
    highlight(input, inputHighlights, "highlight-errors-input");
    highlight(output, spanHighlights, "highlight-spans");
    highlight(output, captureHighlights, "highlight-captures");
  };

  const loadSelectedExample = (selected: string) => {
    const option = getElement<HTMLOptionElement>(`#option-${selected}`);
    updateState({
      selectedExample: selected,
      workspace: "example",
      grammarText: option.dataset.grammar ?? "",
      inputText: option.dataset.input ?? "",
    });
    runWithCaret();
  };

  examplesSelect.addEventListener("change", () => {
    loadSelectedExample(examplesSelect.value);
  });
  scratchButton.addEventListener("click", toggleScratch);

  for (const radio of outputModeRadios) {
    radio.addEventListener("change", () => {
      const outputMode = outputModeFromDom();
      updateState({ outputMode });
      writeStorage(STORAGE_KEYS.outputMode, outputMode);
      runWithCaret();
    });
  }

  input.addEventListener("input", () => {
    updateState({ inputText: input.textContent ?? "" });
    saveScratch();
    runWithCaret();
  });
  grammar.addEventListener("input", () => {
    updateState({ grammarText: grammar.textContent ?? "" });
    saveScratch();
    runWithCaret();
  });

  const defaultSelectedExample = examplesSelect
    .querySelectorAll("option")
    .values()
    .find((e) => e.dataset["defaultSelected"] === "true")?.value;
  const outputModeFromStorage = readStorage(STORAGE_KEYS.outputMode);
  updateState({
    selectedExample:
      readStorage(STORAGE_KEYS.selectedExample) ?? defaultSelectedExample,
    outputMode:
      outputModeFromStorage === "trace" || outputModeFromStorage === "json"
        ? outputModeFromStorage
        : "tree",
  });

  const workspaceFromStorage = readStorage(STORAGE_KEYS.workspace);
  if (workspaceFromStorage === "scratch") {
    toggleScratch();
  } else {
    loadSelectedExample(State.selectedExample);
  }

  window.addEventListener("beforeunload", () => {
    saveScratch();
    writeStorage(STORAGE_KEYS.workspace, State.workspace);
    writeStorage(STORAGE_KEYS.showEmpty, State.options.showEmpty.toString());
    writeStorage(STORAGE_KEYS.selectedExample, State.selectedExample);
    writeStorage(STORAGE_KEYS.outputMode, State.outputMode);
  });
</script>

<Layout>
  <style is:global>
    body {
      display: grid;
      grid-template-areas:
        "grammar output"
        "input   output";
      grid-template-rows: 1fr 1fr;
      grid-template-columns: 1fr 1fr;
      width: 100%;
      height: 100vh;
      padding: 1em;
      gap: 0.5em;
      box-sizing: border-box;
    }

    #input,
    #grammar,
    #output {
      margin: 2px;
      padding: 5px;
      white-space: pre-wrap;
      font-family:
        "Courier Line Draw", "Courier Prime", "Courier New", monospace;
      resize: none;
    }

    #output {
      white-space: pre;
    }

    .content-container {
      overflow-y: scroll;
    }

    .node-label {
      border-radius: 3px;
      padding: 0 2px;
    }

    .input {
      grid-area: input;
    }

    .output {
      grid-area: output;
    }

    .footer {
      grid-area: footer;
    }

    .grammar,
    .input,
    .output {
      display: grid;
      grid-template-rows: auto 1fr;
      border: thin solid gray;
      min-height: 0; /** necessary to prevent divs from growing below screen **/
    }

    .header {
      padding: 5px;
      border-bottom: thin solid gray;
      background: whitesmoke;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
    }

    .trace-options {
      display: flex;
      justify-content: end;
      gap: 0.5rem;
      padding-top: 0.5rem;
      flex-grow: 1;
    }

    .output-mode {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .output-mode-option {
      display: inline-flex;
      align-items: center;
      gap: 0.2rem;
    }

    .examples {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }

    #scratch {
      padding: 0.1rem 0.5rem;
      border: thin solid gray;
      background: white;
      cursor: pointer;
    }

    #scratch.active {
      background: #ddd;
    }

    ::highlight(highlight-spans) {
      color: #555;
    }

    ::highlight(highlight-captures) {
      color: #999;
    }

    ::highlight(highlight-errors-output),
    ::highlight(highlight-errors-grammar),
    ::highlight(highlight-errors-input) {
      text-decoration: red wavy underline;
      background-color: #ffb3ba !important;
    }

    .error-alert {
      flex-grow: 1;
      padding-left: 0.3em;
    }

    .hidden {
      display: none;
    }

    @media (max-width: 768px) {
      body {
        grid-template-areas:
          "title"
          "grammar"
          "input"
          "output"
          "footer";
        grid-template-columns: 1fr;
        grid-template-rows: auto;
        height: auto;
      }

      /**inputs should no longer be scrollable**/
      #grammar,
      #input,
      #output {
        overflow-y: visible;
      }

      /**instead, they should grow**/
      .grammar,
      .input,
      .output {
        min-height: auto;
      }
    }
  </style>

  <div class="grammar">
    <div class="header">
      <label for="grammar">Grammar</label>
      <span class="examples">
        <label for="examples">Examples: </label>
        <select name="examples" id="examples">
          {
            examples.map(({ title, grammar, input }) => (
              <option
                id={`option-${title}`}
                value={title}
                data-grammar={grammar}
                data-input={input}
                data-default-selected={title == initialExample}
              >
                {title}
              </option>
            ))
          }
        </select>
        <button id="scratch" type="button">Scratch</button>
      </span>
    </div>
    <div
      class="content-container"
      id="grammar"
      contenteditable="plaintext-only"
    >
    </div>
  </div>
  <div class="input">
    <div class="header">
      <label for="input">Input</label>
    </div>
    <div class="content-container" id="input" contenteditable="plaintext-only">
    </div>
  </div>
  <div class="output">
    <div class="header">
      Parse Tree
      <span class="error-alert" title="An error occurred during processing"
        >⚠️</span
      >
      <span class="output-mode">
        <label class="output-mode-option">
          <input type="radio" name="output-mode" value="tree" checked />
          Tree
        </label>
        <label class="output-mode-option">
          <input type="radio" name="output-mode" value="trace" />
          Trace
        </label>
        <label class="output-mode-option">
          <input type="radio" name="output-mode" value="json" />
          JSON
        </label>
      </span>
    </div>
    <div class="content-container">
      <div id="output"></div>
    </div>
  </div>
</Layout>
